# ── Shared ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-50-plus-random-chars
DJANGO_DEBUG=true
INTERNAL_SERVICE_TOKEN=change-me-internal-service-token
SENTRY_DSN=

# ── Databases ─────────────────────────────────────────────────────────────────
AUTH_DATABASE_URL=postgresql://envvault:envvault_secret@localhost:5432/auth_db
SECRETS_DATABASE_URL=postgresql://envvault:envvault_secret@localhost:5433/secrets_db
AUDIT_DATABASE_URL=postgresql://envvault:envvault_secret@localhost:5434/audit_db
BILLING_DATABASE_URL=postgresql://envvault:envvault_secret@localhost:5435/billing_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:envvault_redis@localhost:6379/0

# ── Auth Service ──────────────────────────────────────────────────────────────
JWT_SIGNING_KEY=change-me-jwt-secret-key
JWT_ACCESS_TOKEN_LIFETIME=900
JWT_REFRESH_TOKEN_LIFETIME=604800

# ── Secrets Service ───────────────────────────────────────────────────────────
# Generate with: python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
ORG_KEY_DEFAULT=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
AWS_KMS_KEY_ARN=

# ── Billing Service ───────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_METER_ID=mtr_...

# ── Notification Service ──────────────────────────────────────────────────────
SENDGRID_API_KEY=SG....
FROM_EMAIL=notifications@envvault.io
SLACK_BOT_TOKEN=xoxb-...

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXTAUTH_SECRET=change-me-nextauth-secret
NEXTAUTH_URL=http://localhost:3000
